NODE_ENV=production
PORT=3000

# Required — generate with: openssl rand -hex 64
JWT_SECRET=

# MySQL connection string
DATABASE_URL=mysql://chalkpicks:<DB_PASSWORD>@localhost:3306/chalkpicks

# AI picks (LLM) — set to any OpenAI-compatible endpoint (e.g. https://api.openai.com)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# AI pick analysis (OpenAI + Anthropic)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_DAILY=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Email notifications (SendGrid)
SENDGRID_API_KEY=

# SMS notifications (Twilio — optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

APP_URL=https://www.chalkpicks.live

# Cloud-computer worker API (see cloud-computer/README.md)
# Shared secret between chalkpicks.live and the Manus cloud computer.
# Generate with: openssl rand -hex 32 — set the SAME value in both places.
WORKER_API_TOKEN=

# Local LLM on the cloud computer (health-checked; falls back to hosted models).
# Point this at your Manus cloud computer's Ollama endpoint (host:11434/v1).
OLLAMA_API_URL=
OLLAMA_MODEL=qwen3:8b

# IndexNow key (32-hex recommended) for instant Bing/Yandex indexation on blog
# publish (see server/_core/indexnow.ts). Falls back to the pre-shipped
# chalkpicks2026indexnow key if unset, so this is optional.
INDEXNOW_KEY=
